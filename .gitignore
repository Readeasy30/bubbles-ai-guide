# Tokens and local auth
.github-token
.token
token.txt
tokens.txt
pat.txt
GITHUB_PERSONAL_ACCESS_TOKEN*

# MCP / local agent config
mcp.json
.mcp.json
**/mcp.json
**/.mcp.json
.mcp/
.cursor/mcp.json
.vscode/mcp.json
.vscode/settings.json
claude_desktop_config.json

# Private exports or downloaded bundles
private/
_private/
exports/private/

